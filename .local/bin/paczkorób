#!/bin/sh
echo "Kod zadania (3 znaki):"
read kod

echo "Treść (w pdf):"
read pdf

echo "Wzorcówka:"
read wzorcowka

echo "Generatorka:"
read generatorka

echo "Liczba testów:"
read n

mkdir $kod

cp $pdf         $kod/"$kod.pdf"
cp $wzorcowka   $kod/"zad.cpp"
cp $generatorka $kod/"gen.cpp"

cd $kod

mkdir doc # folder na pdf
tmp="zad"
mv "$kod.pdf" doc/"$kod$tmp.pdf"

g++ gen.cpp -o gen
g++ zad.cpp -o zad

mkdir prog # folder na wzorcowki i generatorke

mv "zad.cpp" prog/"$kod.cpp"
mv "gen.cpp" prog/"gen.cpp"

mkdir in out # input, output

for(( i = 1; i <= $n; i++ )); do
  printf "test %d\n" "$i"
  ./gen $i > in/"$kod$i.in"
  ./zad    < in/"$kod$i.in" > out/"$kod$i.out"
done

rm zad gen

echo "Pełny tytuł zadania:"
read full_title

echo "Limit pamięci (kb):"
read memory_limit

echo "limit czasu (ms):"
read time_limit

printf "title: $full_title\nmemory_limit: $memory_limit\ntime_limit: $time_limit" > config.yml

cd ..
zip -r $kod.zip $kod

printf "\nRobienie paczki zakończone.\n"
