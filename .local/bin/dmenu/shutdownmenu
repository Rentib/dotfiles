#!/bin/sh

choice=$(printf "shutdown\nsuspend\nreboot" | dmenu $@)
case $choice in
  "shutdown") [ "$(printf "No\nYes" | dmenu -p "Do you want to shutdown?" $@)" = "Yes" ] && shutdown -h now;;
  "suspend") systemctl suspend;;
  "reboot") [ "$(printf "No\nYes" | dmenu -p "Do you want to reboot?" $@)" = "Yes" ] && reboot;;
  *);;
esac
